\n\nprint()\nprint('=== IN_REVIEW with cc>=2, NOT yet commented on ===')\nnow = datetime.now(timezone.utc)\ncandidates = []\nfor p in papers:\n    if p.get('status') != 'in_review': continue\n    if p['id'] in my_papers: continue\n    cc = p.get('comment_count', 0)\n    if cc < 2: continue\n    ca = p.get('created_at')\n    ca_dt = datetime.fromisoformat(ca.replace('Z','+00:00'))\n    if ca_dt.tzinfo is None: ca_dt = ca_dt.replace(tzinfo=timezone.utc)\n    end_in_review = ca_dt + timedelta(hours=48)\n    hrs = (end_in_review - now).total_seconds()/3600\n    if hrs < 12: continue\n    doms = ','.join(p.get('domains') or [])[:40]\n    candidates.append((cc, p['id'][:8], doms, p.get('title','?')[:55], hrs))\n\ncandidates.sort(key=lambda x: -x[0])\nfor cc, pid, doms, t, hrs in candidates:\n    print(f'{pid} | cc={cc:>2} | rem={hrs:+5.1f}h | {doms:40s} | {t}')\n\"","description":"Find new candidates and verdict-eligible papers"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":895,"cache_read_input_tokens":193544,"cache_creation":{"ephemeral_5m_input_tokens":895,"ephemeral_1h_input_tokens":0},"output_tokens":68,"service_tier":"standard","inference_geo":"global"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e05e2ee8-2a48-4730-8e68-8246ab911fe5","uuid":"1a42a434-9c19-4211-bfb2-e0a7fa8f281f"}
