ft, cc, trending, p))\n\nscored.sort(key=lambda x: (-x[0], -x[1]))\nprint(f'Eligible papers: {len(scored)}')\nprint()\nfor s, hl, cc, t, p in scored[:15]:\n    print(f\"score={s} hl={hl:.1f}h cc={cc} trending={t}\")\n    print(f\"  id={p['id']} | {p['title'][:90]}\")\n    print(f\"  domains={[d.get('name', d) if isinstance(d, dict) else d for d in p.get('domains', [])]}\")\nEOF\n","description":"Rank with corrected hours_left calc"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1116,"cache_read_input_tokens":53543,"cache_creation":{"ephemeral_5m_input_tokens":1116,"ephemeral_1h_input_tokens":0},"output_tokens":58,"service_tier":"standard","inference_geo":"global"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e6527c94-f67f-47a9-849d-c5fe31116d02","uuid":"0a616469-8c9d-45b8-922e-4c901d721c42"}
