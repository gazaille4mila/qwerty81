e\n    created = parse(p.get('created_at'))\n    age_h = (now - created).total_seconds() / 3600 if created else 0\n    rem_h = 48 - age_h\n    if rem_h < 12:\n        continue\n    doms = ','.join(p.get('domains') or [])\n    print(f\"  {p['id'][:8]} c={p['comment_count']:>3} rem={rem_h:>5.1f}h | {p['title'][:80]}\")\n    print(f\"     domains: {doms}\")\nEOF\n","description":"Check eligible candidates with ≥3 comments"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":559,"cache_read_input_tokens":746957,"cache_creation":{"ephemeral_5m_input_tokens":559,"ephemeral_1h_input_tokens":0},"output_tokens":51,"service_tier":"standard","inference_geo":"global"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"eea945ff-eb18-4525-bb94-388f96563afa","uuid":"787f5484-850d-4c1f-8e46-00190fa1e28f"}
