{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_015Gd4d95P6VprmhgYqqP1NE","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01QyRr1jRCL5bmkNePvNWRnT","name":"mcp__koala__get_paper","input":{"paper_id":"ef666d10-db2a-456f-a5c4-33d0c0717a77"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3255,"cache_read_input_tokens":233423,"cache_creation":{"ephemeral_5m_input_tokens":3255,"ephemeral_1h_input_tokens":0},"output_tokens":50,"service_tier":"standard","inference_geo":"global"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"80053081-ac83-483f-ab5a-50ade4c3171d","uuid":"abcf2e4c-ce39-4f89-8b4e-bd696a2384e5"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QyRr1jRCL5bmkNePvNWRnT","type":"tool_result","content":"{\"result\":\"{\\n  \\\"title\\\": \\\"SpatialAnt: Autonomous Zero-Shot Robot Navigation via Active Scene Reconstruction and Visual Anticipation\\\",\\n  \\\"abstract\\\": \\\"Vision-and-Language Navigation (VLN) has recently benefited from Multimodal Large Language Models (MLLMs), enabling zero-shot navigation. While recent exploration-based zero-shot methods have shown promising results by leveraging global scene priors, they rely on high-quality human-crafted scene reconstructions, which are impractical for real-world robot deployment. When encountering an unseen environment, a robot should build its own priors through pre-exploration. However, these self-built reconstructions are inevitably incomplete and noisy, which severely degrade methods that depend on high-quality scene reconstructions. To address these issues, we propose SpatialAnt, a zero-shot navigation framework designed to bridge the gap between imperfect self-reconstructions and robust execution. SpatialAnt introduces a physical grounding strategy to recover the absolute metric scale for monocular-based reconstructions. Furthermore, rather than treating the noisy self-reconstructed scenes as absolute spatial references, we propose a novel visual anticipation mechanism. This mechanism leverages the noisy point clouds to render future observations, enabling the agent to perform counterfactual reasoning and prune paths that contradict human instructions. Extensive experiments in both simulated and real-world environments demonstrate that SpatialAnt significantly outperforms existing zero-shot methods. We achieve a 66% Success Rate (SR) on R2R-CE and 50.8% SR on RxR-CE benchmarks. Physical deployment on a Hello Robot further confirms the efficiency and efficacy of our framework, achieving a 52% SR in challenging real-world settings.\\\",\\n  \\\"domains\\\": [\\n    \\\"d/Robotics\\\",\\n    \\\"d/Computer-Vision\\\",\\n    \\\"d/NLP\\\"\\n  ],\\n  \\\"pdf_url\\\": \\\"/storage/pdfs/ef666d10-db2a-456f-a5c4-33d0c0717a77.pdf\\\",\\n  \\\"github_repo_url\\\": null,\\n  \\\"id\\\": \\\"ef666d10-db2a-456f-a5c4-33d0c0717a77\\\",\\n  \\\"submitter_id\\\": \\\"84bf7150-feea-446b-a861-3f37f82f81be\\\",\\n  \\\"submitter_type\\\": \\\"human\\\",\\n  \\\"submitter_name\\\": \\\"Koala Bot\\\",\\n  \\\"preview_image_url\\\": \\\"/storage/previews/d9f1c9f77f4d443ba88c293379dbd64b.png\\\",\\n  \\\"tarball_url\\\": \\\"/storage/tarballs/ef666d10-db2a-456f-a5c4-33d0c0717a77.tar.gz\\\",\\n  \\\"github_urls\\\": [],\\n  \\\"comment_count\\\": 0,\\n  \\\"arxiv_id\\\": \\\"2603.26837\\\",\\n  \\\"status\\\": \\\"in_review\\\",\\n  \\\"deliberating_at\\\": null,\\n  \\\"created_at\\\": \\\"2026-04-26T20:00:01.312969\\\",\\n  \\\"updated_at\\\": \\\"2026-04-24T13:31:37.401942\\\"\\n}\"}"}]},"parent_tool_use_id":null,"session_id":"80053081-ac83-483f-ab5a-50ade4c3171d","uuid":"fa11fe5d-fd6b-4bec-968d-26376fd88f14","timestamp":"2026-04-27T14:19:31.175Z","tool_use_result":{"content":"{\"result\":\"{\\n  \\\"title\\\": \\\"SpatialAnt: Autonomous Zero-Shot Robot Navigation via Active Scene Reconstruction and Visual Anticipation\\\",\\n  \\\"abstract\\\": \\\"Vision-and-Language Navigation (VLN) has recently benefited from Multimodal Large Language Models (MLLMs), enabling zero-shot navigation. While recent exploration-based zero-shot methods have shown promising results by leveraging global scene priors, they rely on high-quality human-crafted scene reconstructions, which are impractical for real-world robot deployment. When encountering an unseen environment, a robot should build its own priors through pre-exploration. However, these self-built reconstructions are inevitably incomplete and noisy, which severely degrade methods that depend on high-quality scene reconstructions. To address these issues, we propose SpatialAnt, a zero-shot navigation framework designed to bridge the gap between imperfect self-reconstructions and robust execution. SpatialAnt introduces a physical grounding strategy to recover the absolute metric scale for monocular-based reconstructions. Furthermore, rather than treating the noisy self-reconstructed scenes as absolute spatial references, we propose a novel visual anticipation mechanism. This mechanism leverages the noisy point clouds to render future observations, enabling the agent to perform counterfactual reasoning and prune paths that contradict human instructions. Extensive experiments in both simulated and real-world environments demonstrate that SpatialAnt significantly outperforms existing zero-shot methods. We achieve a 66% Success Rate (SR) on R2R-CE and 50.8% SR on RxR-CE benchmarks. Physical deployment on a Hello Robot further confirms the efficiency and efficacy of our framework, achieving a 52% SR in challenging real-world settings.\\\",\\n  \\\"domains\\\": [\\n    \\\"d/Robotics\\\",\\n    \\\"d/Computer-Vision\\\",\\n    \\\"d/NLP\\\"\\n  ],\\n  \\\"pdf_url\\\": \\\"/storage/pdfs/ef666d10-db2a-456f-a5c4-33d0c0717a77.pdf\\\",\\n  \\\"github_repo_url\\\": null,\\n  \\\"id\\\": \\\"ef666d10-db2a-456f-a5c4-33d0c0717a77\\\",\\n  \\\"submitter_id\\\": \\\"84bf7150-feea-446b-a861-3f37f82f81be\\\",\\n  \\\"submitter_type\\\": \\\"human\\\",\\n  \\\"submitter_name\\\": \\\"Koala Bot\\\",\\n  \\\"preview_image_url\\\": \\\"/storage/previews/d9f1c9f77f4d443ba88c293379dbd64b.png\\\",\\n  \\\"tarball_url\\\": \\\"/storage/tarballs/ef666d10-db2a-456f-a5c4-33d0c0717a77.tar.gz\\\",\\n  \\\"github_urls\\\": [],\\n  \\\"comment_count\\\": 0,\\n  \\\"arxiv_id\\\": \\\"2603.26837\\\",\\n  \\\"status\\\": \\\"in_review\\\",\\n  \\\"deliberating_at\\\": null,\\n  \\\"created_at\\\": \\\"2026-04-26T20:00:01.312969\\\",\\n  \\\"updated_at\\\": \\\"2026-04-24T13:31:37.401942\\\"\\n}\"}","_meta":{"fastmcp":{"wrap_result":true}},"structuredContent":{"result":"{\n  \"title\": \"SpatialAnt: Autonomous Zero-Shot Robot Navigation via Active Scene Reconstruction and Visual Anticipation\",\n  \"abstract\": \"Vision-and-Language Navigation (VLN) has recently benefited from Multimodal Large Language Models (MLLMs), enabling zero-shot navigation. While recent exploration-based zero-shot methods have shown promising results by leveraging global scene priors, they rely on high-quality human-crafted scene reconstructions, which are impractical for real-world robot deployment. When encountering an unseen environment, a robot should build its own priors through pre-exploration. However, these self-built reconstructions are inevitably incomplete and noisy, which severely degrade methods that depend on high-quality scene reconstructions. To address these issues, we propose SpatialAnt, a zero-shot navigation framework designed to bridge the gap between imperfect self-reconstructions and robust execution. SpatialAnt introduces a physical grounding strategy to recover the absolute metric scale for monocular-based reconstructions. Furthermore, rather than treating the noisy self-reconstructed scenes as absolute spatial references, we propose a novel visual anticipation mechanism. This mechanism leverages the noisy point clouds to render future observations, enabling the agent to perform counterfactual reasoning and prune paths that contradict human instructions. Extensive experiments in both simulated and real-world environments demonstrate that SpatialAnt significantly outperforms existing zero-shot methods. We achieve a 66% Success Rate (SR) on R2R-CE and 50.8% SR on RxR-CE benchmarks. Physical deployment on a Hello Robot further confirms the efficiency and efficacy of our framework, achieving a 52% SR in challenging real-world settings.\",\n  \"domains\": [\n    \"d/Robotics\",\n    \"d/Computer-Vision\",\n    \"d/NLP\"\n  ],\n  \"pdf_url\": \"/storage/pdfs/ef666d10-db2a-456f-a5c4-33d0c0717a77.pdf\",\n  \"github_repo_url\": null,\n  \"id\": \"ef666d10-db2a-456f-a5c4-33d0c0717a77\",\n  \"submitter_id\": \"84bf7150-feea-446b-a861-3f37f82f81be\",\n  \"submitter_type\": \"human\",\n  \"submitter_name\": \"Koala Bot\",\n  \"preview_image_url\": \"/storage/previews/d9f1c9f77f4d443ba88c293379dbd64b.png\",\n  \"tarball_url\": \"/storage/tarballs/ef666d10-db2a-456f-a5c4-33d0c0717a77.tar.gz\",\n  \"github_urls\": [],\n  \"comment_count\": 0,\n  \"arxiv_id\": \"2603.26837\",\n  \"status\": \"in_review\",\n  \"deliberating_at\": null,\n  \"created_at\": \"2026-04-26T20:00:01.312969\",\n  \"updated_at\": \"2026-04-24T13:31:37.401942\"\n}"}}}
