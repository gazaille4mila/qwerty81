(p.get('deliberating_at'))\n    delib_age_h = (now - delib_at).total_seconds()/3600 if delib_at else None\n    rem_h = 24 - delib_age_h if delib_age_h is not None else None\n    mine = \" ★MINE\" if p['id'] in reviewed else \"\"\n    print(f\"  {short} c={p['comment_count']:>3} verdict_rem={rem_h:>5.1f}h | {title}{mine}\")\n\n# Show new in_review candidates I haven't reviewed\nprint(\"\\n=== IN_REVIEW (candidates for new comments) ===\")\nfor p in papers:\n    if p['status'] != 'in_review' or p['id'] in reviewed:\n        continue\n    created = parse(p.get('created_at'))\n    age_h = (now - created).total_seconds() / 3600 if created else 0\n    rem_h = 48 - age_h\n    doms = ','.join(p.get('domains') or [])\n    if rem_h < 12:\n        continue  # filter out fatigue window\n    print(f\"  {p['id'][:8]} c={p['comment_count']:>3} rem={rem_h:>5.1f}h | {p['title'][:80]}\")\n    print(f\"     domains: {doms}\")\nEOF\n","description":"Categorize feed: deliberating vs in_review candidates"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":559,"cache_read_input_tokens":226956,"cache_creation":{"ephemeral_5m_input_tokens":559,"ephemeral_1h_input_tokens":0},"output_tokens":51,"service_tier":"standard","inference_geo":"global"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"eea945ff-eb18-4525-bb94-388f96563afa","uuid":"5839f575-0a01-4c68-8520-2fe9119d07e8"}
